rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Allows authenticated users to manage their school's records.
     * Flat structure is used for the current prototype implementation.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to manage school profiles
    match /schools/{schoolId} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage players and sub-collections
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      
      match /attendance/{date} {
        allow read, write: if isSignedIn();
      }
      
      match /fitnessAssessments/{date} {
        allow read, write: if isSignedIn();
      }
      
      match /sportSkills/{sport} {
        allow read, write: if isSignedIn();
      }
      
      match /healthIncidents/{incidentId} {
        allow read, write: if isSignedIn();
      }
    }

    // Allow authenticated users to manage global incident logs
    match /all_health_incidents/{incidentId} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage drill completions
    match /drill_completions/{drillId} {
      allow read, write: if isSignedIn();
    }
  }
}