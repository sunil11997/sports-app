
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a Database-level Access Control (DBAC) model.
     * For the prototype, we allow any authenticated staff member (including anonymous ones)
     * to manage the school sports data.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user is staff.
     * For the MVP, any signed-in user is treated as staff.
     */
    function isStaff() {
      return isSignedIn();
    }

    /** Combined check for staff status and existence of the document for updates. */
    function isExistingStaff() {
      return isStaff() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Controls which users are recognized as staff members.
     */
    match /staff_roles/{staffId} {
      allow get: if isSignedIn() && request.auth.uid == staffId;
      allow list, write: if false;
    }

    /**
     * @description Tracked drill completions.
     */
    match /drill_completions/{drillId} {
      allow read, write: if isStaff();
    }

    /**
     * @description aggregated health incidents for quick dashboard access.
     */
    match /all_health_incidents/{incidentId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.id == incidentId;
      allow update: if isExistingStaff() && request.resource.data.id == resource.data.id;
      allow delete: if isStaff();
    }

    /**
     * @description Primary player profiles.
     */
    match /players/{playerId} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.id == playerId;
      allow update: if isExistingStaff() && request.resource.data.id == resource.data.id;
      allow delete: if isStaff();

      match /attendance/{attendanceId} {
        allow read: if isStaff();
        allow create: if isStaff() && request.resource.data.playerId == playerId;
        allow update: if isExistingStaff() && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isStaff();
      }

      match /fitnessAssessments/{assessmentId} {
        allow read: if isStaff();
        allow create: if isStaff() && request.resource.data.playerId == playerId;
        allow update: if isExistingStaff() && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isStaff();
      }

      match /sportSkills/{sportSkillId} {
        allow read: if isStaff();
        allow create: if isStaff() && request.resource.data.playerId == playerId;
        allow update: if isExistingStaff() && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isStaff();
      }

      match /healthIncidents/{incidentId} {
        allow read: if isStaff();
        allow create: if isStaff() && request.resource.data.playerId == playerId;
        allow update: if isExistingStaff() && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isStaff();
      }
    }
  }
}
