rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Allows authenticated users to manage their school's records.
     * Uses recursive wildcards to ensure collection listing and sub-collection access.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to manage school profiles
    match /schools/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage players and all nested data (attendance, fitness, etc.)
    match /players/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage global incident logs
    match /all_health_incidents/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage drill completions
    match /drill_completions/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Catch-all for any other authenticated access during development
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}