
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * Allows authenticated users to manage their school's records.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to manage school profiles
    match /schools/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Allow authenticated users to manage players
    match /players/{document=**} {
      allow read, write: if isSignedIn();
    }

    // New Root-Level Registries
    match /attendance_registry/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /fitness_registry/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /skills_registry/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Global Activity and Incident logs
    match /all_health_incidents/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /school_activities/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /drill_completions/{document=**} {
      allow read, write: if isSignedIn();
    }

    // Catch-all for development
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
